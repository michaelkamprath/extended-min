int passed = 0
int failed = 0
int t1 = 0; int t2 = 0; int t3 = 0; int t4 = 0; int t5 = 0; int t6 = 0; int t7 = 0
int t8 = 0; int t9 = 0; int t10 = 0; int t11 = 0; int t12 = 0; int t13 = 0; int t14 = 0

def show_pass(int n, int s):
  if s == 1:
    print(n); print(" ")

def show_fail(int n, int s):
  if s == -1:
    print(n); print(" ")

long a = 70000
long b = 2
long c = a + b
long d = c - 5
long e = -long(9)
long f = (long(1) << 12) or 0x33
long g = f xor 0x0f
long h = g and 0x0fff
long i = h >> 3
long j = not long(0)

# Test 1: long addition.
if c == 70002:
  passed += 1; t1 = 1
else:
  print("FAIL 1 long add\n")
  failed += 1; t1 = -1

# Test 2: long subtraction.
if d == 69997:
  passed += 1; t2 = 1
else:
  print("FAIL 2 long sub\n")
  failed += 1; t2 = -1

# Test 3: unary minus on long.
if e == -9:
  passed += 1; t3 = 1
else:
  print("FAIL 3 long neg\n")
  failed += 1; t3 = -1

# Test 4: long bitwise `or` with shift-built lhs.
if f == 4147:
  passed += 1; t4 = 1
else:
  print("FAIL 4 long or\n")
  failed += 1; t4 = -1

# Test 5: long bitwise `xor`.
if g == 4156:
  passed += 1; t5 = 1
else:
  print("FAIL 5 long xor\n")
  failed += 1; t5 = -1

# Test 6: long bitwise `and`.
if h == 60:
  passed += 1; t6 = 1
else:
  print("FAIL 6 long and\n")
  failed += 1; t6 = -1

# Test 7: long right shift.
if i == 7:
  passed += 1; t7 = 1
else:
  print("FAIL 7 long shr\n")
  failed += 1; t7 = -1

# Test 8: long bitwise `not`.
if j == -1:
  passed += 1; t8 = 1
else:
  print("FAIL 8 long not\n")
  failed += 1; t8 = -1

long x = 70000
long y = 70000
long z = 70001
long n = 3
long truthy = 1

# Test 9: long equality in control flow.
if x == y:
  passed += 1; t9 = 1
else:
  print("FAIL 9 long eq\n")
  failed += 1; t9 = -1

# Test 10: long greater-than in control flow.
if z > y:
  passed += 1; t10 = 1
else:
  print("FAIL 10 long gt\n")
  failed += 1; t10 = -1

# Test 11: non-zero long truthiness in control flow.
if truthy:
  passed += 1; t11 = 1
else:
  print("FAIL 11 long truthy\n")
  failed += 1; t11 = -1

int loop_sum = 0
while n >= 1:
  loop_sum += n
  n = n - 1
# Test 12: long `while` condition and loop-carried arithmetic.
if loop_sum == 6:
  passed += 1; t12 = 1
else:
  print("FAIL 12 long while\n")
  failed += 1; t12 = -1

def mismatchLoop():
  int ii = 0
  int hits = 0
  while ii < 40:
    if ii == 300:
      hits += 1000
    if ii != 300:
      hits += 1
    ii += 1
  return hits

# Test 13: repeated int `==`/`!=` checks remain stack-balanced.
if mismatchLoop() == 40:
  passed += 1; t13 = 1
else:
  print("FAIL 13 eq neq balance\n")
  failed += 1; t13 = -1

def countdown(int n2):
  int sum = 0
  while n2 > 1:
    sum += n2
    n2 = n2 - 1
  return sum

# Test 14: int `>` still works after long/control-flow changes.
if countdown(4) == 9:
  passed += 1; t14 = 1
else:
  print("FAIL 14 int gt ctrl\n")
  failed += 1; t14 = -1

print("PASS ")
show_pass(1, t1); show_pass(2, t2); show_pass(3, t3); show_pass(4, t4); show_pass(5, t5); show_pass(6, t6); show_pass(7, t7)
show_pass(8, t8); show_pass(9, t9); show_pass(10, t10); show_pass(11, t11); show_pass(12, t12); show_pass(13, t13); show_pass(14, t14)
print("\nFAIL ")
show_fail(1, t1); show_fail(2, t2); show_fail(3, t3); show_fail(4, t4); show_fail(5, t5); show_fail(6, t6); show_fail(7, t7)
show_fail(8, t8); show_fail(9, t9); show_fail(10, t10); show_fail(11, t11); show_fail(12, t12); show_fail(13, t13); show_fail(14, t14)
print("\np5opsctl PASS=")
print(passed)
print(" FAIL=")
print(failed)
print("\n")
