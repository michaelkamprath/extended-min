# Test 12: long lhs `<` int rhs false case.
if r < t:
  print("FAIL 12 l<i false\n")
  failed += 1; t12 = -1
else:
  passed += 1; t12 = 1

int u = 100
long v = 100
# Test 13: int lhs `<=` long rhs equality case.
if u <= v:
  passed += 1; t13 = 1
else:
  print("FAIL 13 i<=l eq\n")
  failed += 1; t13 = -1

long w = 200
# Test 14: int lhs `<=` long rhs less-than case.
if u <= w:
  passed += 1; t14 = 1
else:
  print("FAIL 14 i<=l lt\n")
  failed += 1; t14 = -1

long x = 100
int y = 100
# Test 15: long lhs `<=` int rhs equality case.
if x <= y:
  passed += 1; t15 = 1
else:
  print("FAIL 15 l<=i eq\n")
  failed += 1; t15 = -1

