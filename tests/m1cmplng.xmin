int passed = 0
int failed = 0
int t1 = 0; int t2 = 0; int t3 = 0; int t4 = 0; int t5 = 0; int t6 = 0; int t7 = 0
int t8 = 0; int t9 = 0; int t10 = 0; int t11 = 0; int t12 = 0; int t13 = 0; int t14 = 0
int t15 = 0; int t16 = 0; int t17 = 0; int t18 = 0; int t19 = 0; int t20 = 0; int t21 = 0
int t22 = 0; int t23 = 0; int t24 = 0; int t25 = 0; int t26 = 0; int t27 = 0; int t28 = 0

def show_pass(int n, int s):
  if s == 1:
    print(n); print(" ")

def show_fail(int n, int s):
  if s == -1:
    print(n); print(" ")

int a = 100
long b = 100
# Test 1: int lhs `==` long rhs true case.
if a == b:
  passed += 1; t1 = 1
else:
  print("FAIL 1 i==l\n")
  failed += 1; t1 = -1

long c = 200
# Test 2: int lhs `==` long rhs false case.
if a == c:
  print("FAIL 2 i==l false\n")
  failed += 1; t2 = -1
else:
  passed += 1; t2 = 1

long d = 100
int e = 100
# Test 3: long lhs `==` int rhs true case.
if d == e:
  passed += 1; t3 = 1
else:
  print("FAIL 3 l==i\n")
  failed += 1; t3 = -1

int f = 50
# Test 4: long lhs `==` int rhs false case.
if d == f:
  print("FAIL 4 l==i false\n")
  failed += 1; t4 = -1
else:
  passed += 1; t4 = 1

int g = 50
long h = 100
# Test 5: int lhs `!=` long rhs true case.
if g != h:
  passed += 1; t5 = 1
else:
  print("FAIL 5 i!=l\n")
  failed += 1; t5 = -1

long i = 50
# Test 6: int lhs `!=` long rhs false case.
if g != i:
  print("FAIL 6 i!=l false\n")
  failed += 1; t6 = -1
else:
  passed += 1; t6 = 1

long j = 200
int k = 100
# Test 7: long lhs `!=` int rhs true case.
if j != k:
  passed += 1; t7 = 1
else:
  print("FAIL 7 l!=i\n")
  failed += 1; t7 = -1

int m = 200
# Test 8: long lhs `!=` int rhs false case.
if j != m:
  print("FAIL 8 l!=i false\n")
  failed += 1; t8 = -1
else:
  passed += 1; t8 = 1

int n = 50
long p = 100
# Test 9: int lhs `<` long rhs true case.
if n < p:
  passed += 1; t9 = 1
else:
  print("FAIL 9 i<l\n")
  failed += 1; t9 = -1

long q = 25
# Test 10: int lhs `<` long rhs false case.
if n < q:
  print("FAIL 10 i<l false\n")
  failed += 1; t10 = -1
else:
  passed += 1; t10 = 1

long r = 25
int s = 100
