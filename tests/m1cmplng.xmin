  passed += 1; t24 = 1
else:
  print("FAIL 24 l>=i gt\n")
  failed += 1; t24 = -1

int an = 1000
long ap = 50000
# Test 25: small int compared with large long.
if an < ap:
  passed += 1; t25 = 1
else:
  print("FAIL 25 small<big\n")
  failed += 1; t25 = -1

# Test 26: large long compared with small int.
if ap > an:
  passed += 1; t26 = 1
else:
  print("FAIL 26 big>small\n")
  failed += 1; t26 = -1

int INTVAL100 := 100
int INTVAL50 := 50
long LONGVAL100 := 100
long LONGVAL200 := 200
# Test 27: mixed-type constant equality.
if INTVAL100 == LONGVAL100:
  passed += 1; t27 = 1
else:
  print("FAIL 27 const eq\n")
  failed += 1; t27 = -1

# Test 28: mixed-type constant ordering.
if INTVAL50 < LONGVAL200:
  passed += 1; t28 = 1
else:
  print("FAIL 28 const lt\n")
  failed += 1; t28 = -1

print("PASS ")
show_pass(1, t1); show_pass(2, t2); show_pass(3, t3); show_pass(4, t4); show_pass(5, t5); show_pass(6, t6); show_pass(7, t7)
show_pass(8, t8); show_pass(9, t9); show_pass(10, t10); show_pass(11, t11); show_pass(12, t12); show_pass(13, t13); show_pass(14, t14)
