  failed += 1; t18 = -1
else:
  passed += 1; t18 = 1

long ad = 150
int ae = 100
# Test 19: long lhs `>` int rhs true case.
if ad > ae:
  passed += 1; t19 = 1
else:
  print("FAIL 19 l>i\n")
  failed += 1; t19 = -1

