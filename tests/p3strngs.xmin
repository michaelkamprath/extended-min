int passed = 0
int failed = 0
int t1 = 0; int t2 = 0; int t3 = 0; int t4 = 0; int t5 = 0; int t6 = 0; int t7 = 0; int t8 = 0

def show_pass(int n, int s):
  if s == 1:
    print(n); print(" ")

def show_fail(int n, int s):
  if s == -1:
    print(n); print(" ")

char Banner := "HELLO"
string Alias := Banner
char Copy := Alias
char Escaped := "A\nB"

char line = Banner
# Test 1: first character of string const is readable.
if line[0] == 72:
  passed += 1; t1 = 1
else:
  print("FAIL 1 banner[0]\n")
  failed += 1; t1 = -1

# Test 2: later character of string const is readable.
if line[4] == 79:
  passed += 1; t2 = 1
else:
  print("FAIL 2 banner[4]\n")
  failed += 1; t2 = -1

# Test 3: `string` alias can be copied into a `char` buffer.
if Copy[1] == 69:
  passed += 1; t3 = 1
else:
  print("FAIL 3 copy alias\n")
  failed += 1; t3 = -1

# Test 4: escaped string keeps the first character.
if Escaped[0] == 65:
  passed += 1; t4 = 1
else:
  print("FAIL 4 escaped a\n")
  failed += 1; t4 = -1

# Test 5: escaped string keeps the character after newline escape.
if Escaped[2] == 66:
  passed += 1; t5 = 1
else:
  print("FAIL 5 escaped b\n")
  failed += 1; t5 = -1

char Msg := "global"
int saw_local = 0
def show():
  char Msg := "local"
  string Alias2 := Msg
  char LocalCopy = Alias2
  if LocalCopy[0] == 108:
    return 1
  return 0

saw_local = show()
# Test 6: global string-like const remains visible after local shadowing.
if Msg[0] == 103:
  passed += 1; t6 = 1
else:
  print("FAIL 6 global msg\n")
  failed += 1; t6 = -1

# Test 7: local shadow string alias resolves inside the function.
if saw_local == 1:
  passed += 1; t7 = 1
else:
  print("FAIL 7 local msg\n")
  failed += 1; t7 = -1

char AliasLine = Alias
# Test 8: direct alias remains indexable after copy.
if AliasLine[2] == 76:
  passed += 1; t8 = 1
else:
  print("FAIL 8 alias line\n")
  failed += 1; t8 = -1

print("PASS ")
show_pass(1, t1); show_pass(2, t2); show_pass(3, t3); show_pass(4, t4); show_pass(5, t5); show_pass(6, t6); show_pass(7, t7); show_pass(8, t8)
print("\nFAIL ")
show_fail(1, t1); show_fail(2, t2); show_fail(3, t3); show_fail(4, t4); show_fail(5, t5); show_fail(6, t6); show_fail(7, t7); show_fail(8, t8)
print("\np3strngs PASS=")
print(passed)
print(" FAIL=")
print(failed)
print("\n")
