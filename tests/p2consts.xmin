int passed = 0
int failed = 0
int t1 = 0; int t2 = 0; int t3 = 0; int t4 = 0; int t5 = 0; int t6 = 0
int t7 = 0; int t8 = 0; int t9 = 0; int t10 = 0; int t11 = 0; int t12 = 0
int t13 = 0; int t14 = 0; int t15 = 0; int t16 = 0; int t17 = 0; int t18 = 0

def show_pass(int n, int s):
  if s == 1:
    print(n); print(" ")

def show_fail(int n, int s):
  if s == -1:
    print(n); print(" ")

int Start := 100
int Offset := 23
int Total := Start
char Flag := 1
char AliasFlag := Flag

# Test 1: plain int constant declaration.
if Start == 100:
  passed += 1; t1 = 1
else:
  print("FAIL 1 const int\n")
  failed += 1; t1 = -1

# Test 2: int constant alias from another const name.
if Total == 100:
  passed += 1; t2 = 1
else:
  print("FAIL 2 const alias\n")
  failed += 1; t2 = -1

# Test 3: char constant alias.
if AliasFlag == 1:
  passed += 1; t3 = 1
else:
  print("FAIL 3 char alias\n")
  failed += 1; t3 = -1

int ZeroConst := 0x
int a = 0x
char b = 0x
# Test 4: bare `0x` constant declaration resolves to zero.
if ZeroConst == 0:
  passed += 1; t4 = 1
else:
  print("FAIL 4 bare hex const\n")
  failed += 1; t4 = -1

# Test 5: bare `0x` runtime int literal resolves to zero.
if a == 0:
  passed += 1; t5 = 1
else:
  print("FAIL 5 bare hex int\n")
  failed += 1; t5 = -1

# Test 6: bare `0x` runtime char literal resolves to zero.
if b == 0:
  passed += 1; t6 = 1
else:
  print("FAIL 6 bare hex char\n")
  failed += 1; t6 = -1

int MixedConst := 0xAbCd
int UpperConst := 0xFfEe
# Test 7: lowercase prefix with mixed-case digits.
if MixedConst == 0xabcd:
  passed += 1; t7 = 1
else:
  print("FAIL 7 mixed digits\n")
  failed += 1; t7 = -1

# Test 8: mixed-case hexadecimal digits preserve value.
if UpperConst == 0xffee:
  passed += 1; t8 = 1
else:
  print("FAIL 8 upper digits\n")
  failed += 1; t8 = -1

int Big := 0xFEDC
char LowByte := char(Big)
char LowLit := char(0x1234)
int KeptAsInt := char(0xBEEF)
# Test 9: const cast from named int to char.
if LowByte == 0xdc:
  passed += 1; t9 = 1
else:
  print("FAIL 9 cast const name\n")
  failed += 1; t9 = -1

# Test 10: const cast from literal to char.
if LowLit == 0x34:
  passed += 1; t10 = 1
else:
  print("FAIL 10 cast const lit\n")
  failed += 1; t10 = -1

# Test 11: char cast assigned into int keeps narrowed value.
if KeptAsInt == 0xef:
  passed += 1; t11 = 1
else:
  print("FAIL 11 cast kept int\n")
  failed += 1; t11 = -1

int Big2 = 0xFEDC
char Narrow = char(Big2)
char Direct = char(0x1234)
# Test 12: runtime cast from named int to char.
if Narrow == 0xdc:
  passed += 1; t12 = 1
else:
  print("FAIL 12 cast runtime name\n")
  failed += 1; t12 = -1

# Test 13: runtime cast from literal to char.
if Direct == 0x34:
  passed += 1; t13 = 1
else:
  print("FAIL 13 cast runtime lit\n")
  failed += 1; t13 = -1

int charcoal := 0x12AB
int Keep := charcoal
char Low := char(charcoal)
# Test 14: const identifier beginning with `char...` still resolves as a name.
if Keep == 0x12ab:
  passed += 1; t14 = 1
else:
  print("FAIL 14 char prefix keep\n")
  failed += 1; t14 = -1

# Test 15: cast from a `char...`-prefixed const name still narrows correctly.
if Low == 0xab:
  passed += 1; t15 = 1
else:
  print("FAIL 15 char prefix low\n")
  failed += 1; t15 = -1

int Value := 0x1111
def localScope():
  int Value := 0x2222
  int LocalAlias := Value
  return LocalAlias

def globalScope():
  int x = Value
  return x

int localValue = localScope()
int globalValue = globalScope()
# Test 16: local const shadows global const inside a function.
if localValue == 0x2222:
  passed += 1; t16 = 1
else:
  print("FAIL 16 local shadow\n")
  failed += 1; t16 = -1

# Test 17: global const is restored outside the function scope.
if globalValue == 0x1111:
  passed += 1; t17 = 1
else:
  print("FAIL 17 global restore\n")
  failed += 1; t17 = -1

int A := 13
int B2 := 27
int res = A * B2
# Test 18: const values participate in arithmetic normally.
if res == 351:
  passed += 1; t18 = 1
else:
  print("FAIL 18 const mul\n")
  failed += 1; t18 = -1

print("PASS ")
show_pass(1, t1); show_pass(2, t2); show_pass(3, t3); show_pass(4, t4); show_pass(5, t5); show_pass(6, t6)
show_pass(7, t7); show_pass(8, t8); show_pass(9, t9); show_pass(10, t10); show_pass(11, t11); show_pass(12, t12)
show_pass(13, t13); show_pass(14, t14); show_pass(15, t15); show_pass(16, t16); show_pass(17, t17); show_pass(18, t18)
print("\nFAIL ")
show_fail(1, t1); show_fail(2, t2); show_fail(3, t3); show_fail(4, t4); show_fail(5, t5); show_fail(6, t6)
show_fail(7, t7); show_fail(8, t8); show_fail(9, t9); show_fail(10, t10); show_fail(11, t11); show_fail(12, t12)
show_fail(13, t13); show_fail(14, t14); show_fail(15, t15); show_fail(16, t16); show_fail(17, t17); show_fail(18, t18)
print("\np2consts PASS=")
print(passed)
print(" FAIL=")
print(failed)
print("\n")
