int passed = 0
int failed = 0
int t1 = 0; int t2 = 0; int t3 = 0; int t4 = 0; int t5 = 0; int t6 = 0
int t7 = 0; int t8 = 0; int t9 = 0; int t10 = 0; int t11 = 0; int t12 = 0
int t13 = 0; int t14 = 0; int t15 = 0; int t16 = 0; int t17 = 0; int t18 = 0

def show_pass(int n, int s):
  if s == 1:
    print(n); print(" ")

def show_fail(int n, int s):
  if s == -1:
    print(n); print(" ")

int a = 100
int b = 100
int c = 50

# Test 1: `==` true branch for two int variables.
if a == b:
  passed += 1; t1 = 1
else:
  print("FAIL 1 eq true\n")
  failed += 1; t1 = -1

# Test 2: `==` false branch for two int variables.
if a == c:
  print("FAIL 2 eq false\n")
  failed += 1; t2 = -1
else:
  passed += 1; t2 = 1

# Test 3: `!=` true branch for two int variables.
if a != c:
  passed += 1; t3 = 1
else:
  print("FAIL 3 ne true\n")
  failed += 1; t3 = -1

# Test 4: `!=` false branch for equal int variables.
if a != b:
  print("FAIL 4 ne false\n")
  failed += 1; t4 = -1
else:
  passed += 1; t4 = 1

# Test 5: `<` true branch for int variables.
if c < a:
  passed += 1; t5 = 1
else:
  print("FAIL 5 lt true\n")
  failed += 1; t5 = -1

# Test 6: `<` false branch for int variables.
if a < c:
  print("FAIL 6 lt false\n")
  failed += 1; t6 = -1
else:
  passed += 1; t6 = 1

# Test 7: `<=` true branch for less-than case.
if c <= a:
  passed += 1; t7 = 1
else:
  print("FAIL 7 le true\n")
  failed += 1; t7 = -1

# Test 8: `<=` true branch for equality case.
if a <= b:
  passed += 1; t8 = 1
else:
  print("FAIL 8 le eq\n")
  failed += 1; t8 = -1

# Test 9: `>` true branch for int variables.
if a > c:
  passed += 1; t9 = 1
else:
  print("FAIL 9 gt true\n")
  failed += 1; t9 = -1

# Test 10: `>` false branch for int variables.
if c > a:
  print("FAIL 10 gt false\n")
  failed += 1; t10 = -1
else:
  passed += 1; t10 = 1

# Test 11: `>=` true branch for greater-than case.
if a >= c:
  passed += 1; t11 = 1
else:
  print("FAIL 11 ge true\n")
  failed += 1; t11 = -1

# Test 12: `>=` true branch for equality case.
if a >= b:
  passed += 1; t12 = 1
else:
  print("FAIL 12 ge eq\n")
  failed += 1; t12 = -1

int d = 10
int e = 20
int f = d + e
# Test 13: int addition result storage.
if f == 30:
  passed += 1; t13 = 1
else:
  print("FAIL 13 add\n")
  failed += 1; t13 = -1

int g = 100
int h = 30
int i = g - h
# Test 14: int subtraction result storage.
if i == 70:
  passed += 1; t14 = 1
else:
  print("FAIL 14 sub\n")
  failed += 1; t14 = -1

int j = 5
int k = 7
int m = j * k
# Test 15: int multiplication result storage.
if m == 35:
  passed += 1; t15 = 1
else:
  print("FAIL 15 mul\n")
  failed += 1; t15 = -1

int n = 100
int p = 5
int q = n / p
# Test 16: int division result storage.
if q == 20:
  passed += 1; t16 = 1
else:
  print("FAIL 16 div\n")
  failed += 1; t16 = -1

int r = 0xff
int s = 0x0f
int t = r and s
# Test 17: bitwise `and` result storage.
if t == 15:
  passed += 1; t17 = 1
else:
  print("FAIL 17 and\n")
  failed += 1; t17 = -1

int u = 5
int v = 3
int w = 2
int x = u + v * w
# Test 18: nested precedence between `+` and `*`.
if x == 11:
  passed += 1; t18 = 1
else:
  print("FAIL 18 nested\n")
  failed += 1; t18 = -1

print("PASS ")
show_pass(1, t1); show_pass(2, t2); show_pass(3, t3); show_pass(4, t4); show_pass(5, t5); show_pass(6, t6)
show_pass(7, t7); show_pass(8, t8); show_pass(9, t9); show_pass(10, t10); show_pass(11, t11); show_pass(12, t12)
show_pass(13, t13); show_pass(14, t14); show_pass(15, t15); show_pass(16, t16); show_pass(17, t17); show_pass(18, t18)
print("\nFAIL ")
show_fail(1, t1); show_fail(2, t2); show_fail(3, t3); show_fail(4, t4); show_fail(5, t5); show_fail(6, t6)
show_fail(7, t7); show_fail(8, t8); show_fail(9, t9); show_fail(10, t10); show_fail(11, t11); show_fail(12, t12)
show_fail(13, t13); show_fail(14, t14); show_fail(15, t15); show_fail(16, t16); show_fail(17, t17); show_fail(18, t18)
print("\nm1cmpint PASS=")
print(passed)
print(" FAIL=")
print(failed)
print("\n")
